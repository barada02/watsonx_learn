# Watson Orchestrate Agent Configuration
# Copy this file to .env and fill in your actual values

# Required: Your Watson Orchestrate instance URL (without /v1/orchestrate/runs)
# Example: https://api.jp-tok.watson-orchestrate.cloud.ibm.com/instances/your-instance-id
INSTANCE_URL=https://api.jp-tok.watson-orchestrate.cloud.ibm.com/instances/your-instance-id

# Required: Your IBM Cloud API key
# Get this from: IBM Cloud Console > Manage > Access (IAM) > API keys
API_KEY=your_api_key_here

# Required: Your deployed agent ID
# Get this from: orchestrate agents list (after deploying your agent)
AGENT_ID=your_agent_id_here

# Optional: Token time-to-live in seconds (default: 3000 = 50 minutes)
# TOKEN_TTL_SECONDS=3000

# Note: The token endpoint is automatically set to:
# https://iam.platform.saas.ibm.com/siusermgr/api/1.0/apikeys/token